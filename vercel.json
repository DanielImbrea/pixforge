{
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "pixiqueai.com" }],
      "destination": "https://www.pixiqueai.com/:path*",
      "permanent": true
    }
  ]
}
