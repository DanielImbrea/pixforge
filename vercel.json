{
  "functions": {
    "app/api/jobs/[id]/process/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "pixiqueai.com" }],
      "destination": "https://www.pixiqueai.com/:path*",
      "permanent": true
    }
  ]
}
