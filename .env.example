# =============================================================================
# PixelForge — Environment variables
# Copy to .env.local for development, set in Vercel for production.
# =============================================================================

# App (production: your real domain, no trailing slash)
APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Supabase — URL must be https://xxx.supabase.co WITHOUT /rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (create products/prices in Stripe Dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=

# -----------------------------------------------------------------------------
# AI processing
# -----------------------------------------------------------------------------
# mock  = free local dev (simulated AI, no Replicate account needed)
# replicate = production AI (upscale + background removal via Replicate API)
AI_PROVIDER=mock

# Required when AI_PROVIDER=replicate — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Optional model overrides (defaults work for most cases)
REPLICATE_UPSCALE_MODEL=nightmareai/real-esrgan
REPLICATE_UPSCALE_PHOTO_MODEL=nightmareai/real-esrgan
REPLICATE_UPSCALE_UI_MODEL=nightmareai/real-esrgan
REPLICATE_UPSCALE_ART_MODEL=nightmareai/real-esrgan
REPLICATE_BG_REMOVAL_MODEL=851-labs/background-remover
REPLICATE_BG_PRODUCT_MODEL=851-labs/background-remover
REPLICATE_BG_PORTRAIT_MODEL=851-labs/background-remover
REPLICATE_BG_OBJECT_MODEL=851-labs/background-remover
REPLICATE_BG_STUDIO_MODEL=851-labs/background-remover

# Mock webhook HMAC secret (AI_PROVIDER=mock only)
AI_PROVIDER_WEBHOOK_SECRET=dev-secret

# Sharp runs automatically on the server — no API key needed.
# Used for: resize, compress, convert + post-AI WebP/PNG optimization.

# Optional: Cloudflare Turnstile (recommended in production)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional: protects /api/cron/cleanup (Vercel Cron)
CRON_SECRET=

# Optional: unit-economics admin panel on /settings
ADMIN_EMAIL=

# =============================================================================
# PRODUCTION CHECKLIST (Vercel + Supabase + Stripe + Replicate)
# =============================================================================
# 1. Supabase: run migrations 0001, 0002, 0003, 0004 in SQL Editor
# 2. Supabase: create storage buckets uploads, outputs, previews (if not in migration)
# 3. Vercel: set all env vars above; APP_URL=https://your-domain.com
# 4. Set AI_PROVIDER=replicate + REPLICATE_API_TOKEN
# 5. Stripe: webhook to https://your-domain.com/api/webhooks/stripe
# 6. Stripe: paste price IDs for basic/starter/pro
# 7. Deploy — test one Sharp tool (resize) then one AI tool (upscale)
