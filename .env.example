# =============================================================================
# PixiqueAi — Environment variables
# Copy to .env.local for development, set in Vercel for production.
# =============================================================================

# App (production: https://www.pixiqueai.com — no trailing slash)
APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Supabase — URL must be https://xxx.supabase.co WITHOUT /rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (create products/prices in Stripe Dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=

# -----------------------------------------------------------------------------
# AI processing
# -----------------------------------------------------------------------------
# mock  = free local dev (simulated AI, no Replicate account needed)
# replicate = production AI (upscale + background removal via Replicate API)
AI_PROVIDER=mock

# Required when AI_PROVIDER=replicate — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# How long Supabase signed URLs stay valid for Replicate to download inputs (seconds, default 3600)
# REPLICATE_INPUT_URL_TTL_SECONDS=3600

# Optional model overrides (defaults work for most cases)
# Background removal slug ends with -remover (NOT background-removal)
REPLICATE_UPSCALE_MODEL=nightmareai/real-esrgan
REPLICATE_UPSCALE_PHOTO_MODEL=nightmareai/real-esrgan
REPLICATE_UPSCALE_UI_MODEL=nightmareai/real-esrgan
REPLICATE_UPSCALE_ART_MODEL=nightmareai/real-esrgan
# Primary bg model (REPLICATE_BG_MODEL is a legacy alias for REPLICATE_BG_REMOVAL_MODEL)
REPLICATE_BG_REMOVAL_MODEL=851-labs/background-remover
# REPLICATE_BG_MODEL=851-labs/background-remover
# Optional version pin (64-char hash). Leave unset to use built-in pinned version.
# REPLICATE_BG_VERSION=a029dff38972b5fda4ec5d75d7d1cd25aeff621d2cf4946a41055d7db66b80bc
REPLICATE_BG_PRODUCT_MODEL=851-labs/background-remover
REPLICATE_BG_PORTRAIT_MODEL=851-labs/background-remover
REPLICATE_BG_OBJECT_MODEL=851-labs/background-remover
REPLICATE_BG_STUDIO_MODEL=851-labs/background-remover
# Optional model for AI scenic backgrounds in background replace (default: black-forest-labs/flux-schnell)
# REPLICATE_BG_REPLACE_MODEL=black-forest-labs/flux-schnell
# Object removal / magic eraser inpainting (default: black-forest-labs/flux-fill-dev)
# REPLICATE_OBJECT_REMOVE_MODEL=black-forest-labs/flux-fill-dev
# Portrait face restoration (default: sczhou/codeformer)
# REPLICATE_PORTRAIT_ENHANCE_MODEL=sczhou/codeformer
# Blur faces runs on-device (face-api + Sharp) for both automatic and custom modes.
# REPLICATE_BLUR_FACES_* is no longer used — kept only if you revert to a Replicate model.
# REPLICATE_BLUR_FACES_MODEL=kharioki/blur-faces

# Mock webhook HMAC secret (AI_PROVIDER=mock only)
AI_PROVIDER_WEBHOOK_SECRET=dev-secret

# Sharp runs automatically on the server — no API key needed.
# Used for: resize, compress, convert + post-AI WebP/PNG optimization.

# Optional: Cloudflare Turnstile (recommended in production)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional: protects /api/cron/cleanup (Vercel Cron)
CRON_SECRET=

# Optional: unit-economics admin panel on /settings (legacy fallback if role not set)
ADMIN_EMAIL=

# Admin panel: set role in Supabase after migration 0005:
# update public.users set role = 'admin' where email = 'you@example.com';
# Then open /ro/admin or /en/admin

# Contact form (Resend — https://resend.com)
# No Supabase needed: form POST → /api/contact → Resend → your inbox
RESEND_API_KEY=
CONTACT_EMAIL_TO=dani_imbrea@yahoo.com
# Production: verify domain at resend.com, e.g. PixiqueAi Contact <contact@pixiqueai.com>
CONTACT_FROM_EMAIL=PixiqueAi Contact <onboarding@resend.dev>

# =============================================================================
# PRODUCTION CHECKLIST (Vercel + Supabase + Stripe + Replicate)
# =============================================================================
# 1. Supabase: run migrations 0001, 0002, 0003, 0004 in SQL Editor
# 2. Supabase: create storage buckets uploads, outputs, previews (if not in migration)
# 3. Vercel env (Production):
#    APP_URL=https://www.pixiqueai.com
#    NEXT_PUBLIC_APP_URL=https://www.pixiqueai.com
#    AI_PROVIDER=replicate
#    REPLICATE_API_TOKEN=r8_...  (from replicate.com/account/api-tokens)
#    ADMIN_EMAIL=you@example.com  (optional — check GET /api/admin/ai-status when logged in)
# 4. Redeploy after changing env vars
# 5. Stripe: webhook to https://www.pixiqueai.com/api/webhooks/stripe
# 6. Stripe: paste price IDs for basic/starter/pro
# 7. Test: one Sharp tool (resize), then upscale (should take 10–30s via Replicate)
# 8. Replicate billing: add payment method at replicate.com/account/billing
